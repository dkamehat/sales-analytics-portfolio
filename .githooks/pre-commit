#!/usr/bin/env bash
# .githooks/pre-commit
#
# Blocks commits that contain personal information patterns.
# Self-excluding design: this script's own pattern definitions are
# protected via a SELF_EXCLUDE marker so the hook never blocks itself.
#
# Install:
#   git config core.hooksPath .githooks
#   chmod +x .githooks/pre-commit
#
# To override (rare emergency only):
#   SKIP_PERSONAL_INFO_CHECK=1 git commit ...

set -euo pipefail

# SELF_EXCLUDE_BEGIN — patterns below this line are treated as documentation
# of what we block. The script excludes itself and the GitHub Actions workflow
# from the actual content scan to avoid blocking the pattern definitions.

PATTERNS=(
    # Personal names
    "kamehata"
    "kamekichii"
    "Daiki Kamehata"
    "亀畑"

    # Current employer / industry
    "demae"
    "Demae-can"
    "出前館"
    "デマエカン"

    # Previous employers (specific names)
    "Rakuten Payment"
    "Amazon Business Japan"
    "Otaru University"

    # Job-search targets (current selection processes)
    "KOMOJU"
    "Sakana AI"
    "Sansan"
    "SmartHR"
    "Anthropic CSM"

    # Internal stakeholder names
    "立石"
    "藤田"
    "君塚"
    "熊久保"
    "二宮"
    "山田"
    "山本"
    "根岸"
    "芦川"
    "横川"

    # Internal business / project terms
    "お店価格"
    "PJ-W"

    # Personal email / contact
    "kamekichii.banana"

    # Specific internal numbers that identify the employer
    "60,000 merchants"
    "60K merchants"
    "105 sales reps"
    "~105 reps"

    # Credentials / secrets
    "BEGIN RSA PRIVATE KEY"
    "BEGIN OPENSSH PRIVATE KEY"
    
)
# SELF_EXCLUDE_END

if [[ "${SKIP_PERSONAL_INFO_CHECK:-0}" == "1" ]]; then
    echo "⚠️  pre-commit: personal-info check SKIPPED via env var."
    exit 0
fi

# Files staged for commit (excluding this hook itself and the GH Actions workflow)
STAGED=$(git diff --cached --name-only --diff-filter=ACMR \
    | grep -v -E '^\.githooks/pre-commit$' \
    | grep -v -E '^\.github/workflows/check-personal-info\.yml$' \
    | grep -v -E '^docs/PRE-PUBLISH-CHECKLIST\.md$' \
    | grep -v -E '^HOSTING\.md$' || true)

if [[ -z "$STAGED" ]]; then
    exit 0
fi

FOUND_ANY=0
FOUND_REPORT=""

for pattern in "${PATTERNS[@]}"; do
    # Skip empty patterns
    [[ -z "$pattern" ]] && continue

    # grep over staged files (case-insensitive)
    while IFS= read -r file; do
        [[ -z "$file" ]] && continue
        [[ ! -f "$file" ]] && continue

        if grep -li -e "$pattern" "$file" >/dev/null 2>&1; then
            FOUND_ANY=1
            line_hits=$(grep -in -e "$pattern" "$file" | head -3)
            FOUND_REPORT+="  ❌ '$pattern' found in $file:\n$line_hits\n\n"
        fi
    done <<< "$STAGED"
done

if [[ "$FOUND_ANY" == "1" ]]; then
    echo "════════════════════════════════════════════════════════════════"
    echo "  ❌ pre-commit blocked: personal/business information detected"
    echo "════════════════════════════════════════════════════════════════"
    echo ""
    printf "%b" "$FOUND_REPORT"
    echo "Options to proceed:"
    echo "  1. Edit the files to remove the patterns above, then commit again"
    echo "  2. If a hit is a false positive, edit .githooks/pre-commit"
    echo "  3. EMERGENCY override (rare): SKIP_PERSONAL_INFO_CHECK=1 git commit ..."
    echo ""
    echo "See docs/PRE-PUBLISH-CHECKLIST.md for the full review process."
    exit 1
fi

echo "✓ pre-commit: no personal-info patterns detected in staged files."
exit 0
